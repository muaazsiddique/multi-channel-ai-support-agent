# ======================================
# Multi-Channel AI Support Agent
# Environment Variables
# ======================================

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=support-knowledge-base

# Google Sheets (Ticket Tracking)
GOOGLE_SHEETS_CREDENTIALS=your_google_service_account_json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Slack (Human Escalation)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Gmail (Email Support Channel)
GMAIL_CREDENTIALS=configured_via_n8n_oauth

# n8n
N8N_WEBHOOK_BASE_URL=https://your-instance.app.n8n.cloud
